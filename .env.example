# ============================================================
#  IBM Watsonx.ai – Nutrition Agent Configuration
# ============================================================

# IBM Cloud API Key  (create at https://cloud.ibm.com/iam/apikeys)
IBM_API_KEY=hY4P_-OHbQHDUlbZQEqlmrfax7giv_HYb3SK5kBCMSoL

# IBM Watsonx.ai Project ID  (found in your Watsonx project settings)
WATSONX_PROJECT_ID=2fb41680-e02e-49db-bfe6-4e058a1a1791

# Watsonx.ai endpoint URL  (choose region closest to you)
# US-South : https://us-south.ml.cloud.ibm.com
# EU-GB    : https://eu-gb.ml.cloud.ibm.com
# EU-DE    : https://eu-de.ml.cloud.ibm.com
# JP-TOK   : https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://eu-gb.dataplatform.cloud.ibm.com/

# Model ID – pick the model supported by your region
# eu-gb supported: meta-llama/llama-3-3-70b-instruct
#                  meta-llama/llama-4-maverick-17b-128e-instruct-fp8
#                  mistralai/mistral-small-3-1-24b-instruct-2503
# us-south:        ibm/granite-3-8b-instruct  (and many Granite models)
WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# Flask secret key  (change to a long random string in production)
FLASK_SECRET_KEY=change-this-to-a-long-random-secret-string

# Flask environment  (development | production)
FLASK_ENV=development

# Port the app listens on
PORT=5000
